# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# Set default page
DirectoryIndex index.html

# Custom 404 error page
ErrorDocument 404 /404.html

# Remove .html extension from URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.html [L]

# Redirect .html requests to non-.html URLs (optional, for cleaner URLs)
RewriteCond %{THE_REQUEST} ^GET\ /([^.]+)\.html\ 
RewriteRule ^([^.]+)\.html$ /$1 [R=301,L]

# Route specific pages
# Home page
RewriteRule ^home/?$ index.html [QSA,L]

# Shop pages
RewriteRule ^shop/?$ shop.html [QSA,L]
RewriteRule ^shop/collections/?$ shop-collections.html [QSA,L]
RewriteRule ^shop/account/?$ shop-account.html [QSA,L]
RewriteRule ^product/?$ product.html [QSA,L]
RewriteRule ^checkout/?$ checkout.html [QSA,L]

# Information pages
RewriteRule ^about/?$ about.html [QSA,L]
RewriteRule ^contact/?$ contact.html [QSA,L]
RewriteRule ^faq/?$ faq.html [QSA,L]
RewriteRule ^terms/?$ terms.html [QSA,L]

# 404 page
RewriteRule ^page-not-found/?$ page-not-found.html [QSA,L]
RewriteRule ^404/?$ 404.html [QSA,L]

# Prevent access to hidden files and directories
RewriteRule "^\." - [F]

# Compress static files
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  
  # CSS and JavaScript
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  
  # Fonts
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  
  # HTML files
  ExpiresByType text/html "access plus 2 days"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Prevent directory listing
Options -Indexes
